@model BTL_WEB.ViewModels.Services.ServiceFormViewModel

<form asp-action="@(Model.ServiceId.HasValue ? "Edit" : "Create")" method="post" class="compact-form-shell">
    @if (Model.ServiceId.HasValue)
    {
        <input asp-for="ServiceId" type="hidden" />
    }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-2">
        <div class="col-md-7">
            <label asp-for="ServiceName" class="form-label">Tên dịch vụ</label>
            <input asp-for="ServiceName" class="form-control" placeholder="Ví dụ: Tắm thú cưng" />
            <span asp-validation-for="ServiceName" class="text-danger"></span>
        </div>
        <div class="col-md-5">
            <label asp-for="CategoryId" class="form-label">Danh mục</label>
            <select asp-for="CategoryId" class="form-select" asp-items="Model.CategoryOptions"></select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Price" class="form-label">Giá</label>
            <input asp-for="Price" class="form-control" placeholder="Ví dụ: 150000" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-md-5">
            <label asp-for="DurationMinutes" class="form-label">Thời lượng (phút)</label>
            <input asp-for="DurationMinutes" class="form-control" placeholder="Ví dụ: 45" />
            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Status" class="form-label">Trạng thái</label>
            <select asp-for="Status" class="form-select">
                <option value="Active">Đang hoạt động</option>
                <option value="Inactive">Ngừng hoạt động</option>
            </select>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Nhập mô tả dịch vụ..."></textarea>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</form>

<style>
    .compact-form-shell {
        max-width: 920px;
        margin: 0 auto;
        padding: 0 .5rem;
    }

    .compact-form-shell .form-control,
    .compact-form-shell .form-select {
        width: 100%;
        height: 44px;
        border-radius: 8px;
        font-size: 1rem;
    }

    .compact-form-shell textarea.form-control {
        height: auto;
        min-height: 90px;
    }

    .compact-form-shell .form-label {
        margin-bottom: .25rem;
        font-weight: 600;
    }
</style>
